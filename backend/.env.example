# Azure OpenAI (GPT-4o for summarization)
AZURE_OPENAI_ENDPOINT=https://{resource}.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Auth
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Gmail (virajbhatia1611@gmail.com)
GMAIL_ADDRESS=virajbhatia1611@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_POLL_INTERVAL_SECONDS=30

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_USE_POLLING=true

# Meta — WhatsApp (fill after GCP deploy)
WHATSAPP_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=contextflow-verify-secret
META_APP_SECRET=

# Meta — Instagram (fill after GCP deploy)
INSTAGRAM_PAGE_ID=

# Storage (relative to where you run uvicorn)
DATA_DIR=./data
SQLITE_DB_PATH=./data/contextflow.db
LANCEDB_PATH=./data/lancedb
UPLOAD_DIR=./data/uploads
